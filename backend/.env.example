# TokenForge Backend — Environment Variables
# Copy this file to backend/.env and fill in all REPLACE_WITH_... values.
# Generate JWT_SECRET with: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Required ─────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_char_hex_secret
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=tokenforge
STRIPE_API_KEY=REPLACE_WITH_sk_live_or_sk_test_key

# ── Admin account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tokenforge.io
ADMIN_PASSWORD=REPLACE_WITH_strong_password

# ── LLM providers (platform-level keys) ──────────────────────────────────────
# At least one key is required for the /proxy/chat endpoint to function.
# Groq (free tier — fastest, recommended first): https://console.groq.com/keys
GROQ_API_KEY=REPLACE_WITH_groq_key

# Gemini (free tier — best quality free): https://aistudio.google.com/apikey
GOOGLE_API_KEY=REPLACE_WITH_gemini_key

# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (paid): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Email (Resend — free tier 3k/mo): https://resend.com/api-keys ─────────────
RESEND_API_KEY=REPLACE_WITH_re_key
FROM_EMAIL=noreply@alreadyherellc.com

# ── Stripe webhook (add after running: stripe listen --forward-to ...) ────────
STRIPE_WEBHOOK_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://forge.alreadyherellc.com,http://localhost:3000

# ── Pollinations fallback (keyless, always available) ─────────────────────────
# Set to "false" to disable. Default: enabled.
LLM_POLLINATIONS_FALLBACK=true

# ── ASI Engine ────────────────────────────────────────────────────────────────
# Auto-deploy switch: false = patches saved for review, true = live hot-swap
ASI_AUTO_DEPLOY=false
CLUSTER_SECRET=REPLACE_WITH_cluster_secret
# GEMINI_API_KEY already listed above (reused by ASI engine)
# ---- Video Engine ----
VIDEO_ENGINE_COMPILE=true
VIDEO_TEMPORAL_STRIDE=10
VIDEO_VARIANCE_THRESHOLD=0.012
