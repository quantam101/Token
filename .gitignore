# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Emergent agent files (never commit) ──────────────────────────────────────
.gitconfig
.emergent/
memory/
test_reports/
test_result.md
design_guidelines.json
tests/__init__.py

# ── IDE and editors ───────────────────────────────────────────────────────────
.idea/
.vscode/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Next.js / CRA builds ──────────────────────────────────────────────────────
/.next/
/out/
next-env.d.ts
*.tsbuildinfo
/build
dist/

# ── Environment and secrets (NEVER COMMIT) ───────────────────────────────────
.env
.env.*
*.env
backend/.env
*token.json*
*credentials.json*
credentials.json
*.key
.credentials

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ── System ────────────────────────────────────────────────────────────────────
.DS_Store
*.pem

# ── Dev tools ─────────────────────────────────────────────────────────────────
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac
.vercel
.cache/

# ── Data / databases ──────────────────────────────────────────────────────────
agenthub/agents/youtube/db

# ── Large assets ──────────────────────────────────────────────────────────────
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ── Frontend cache ────────────────────────────────────────────────────────────
frontend/node_modules/.cache/
